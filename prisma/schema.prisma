generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  password      String?
  image         String?
  locale        String    @default("ko")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts   Account[]
  sessions   Session[]
  portfolios Portfolio[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Portfolio {
  id        String   @id @default(cuid())
  userId    String
  name      String
  currency  String   @default("USD")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  assets Asset[]
}

model Asset {
  id          String    @id @default(cuid())
  portfolioId String
  symbol      String
  name        String
  assetType   AssetType
  exchange    String?
  currency    String    @default("USD")
  shares      Float
  avgCost     Float
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  portfolio    Portfolio     @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  dividends    Dividend[]
}

model Transaction {
  id      String          @id @default(cuid())
  assetId String
  type    TransactionType
  shares  Float
  price   Float
  date    DateTime
  note    String?

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model Dividend {
  id       String   @id @default(cuid())
  assetId  String
  amount   Float
  currency String   @default("USD")
  date     DateTime

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

enum AssetType {
  STOCK
  ETF
  BOND
  CRYPTO
  OTHER
}

enum TransactionType {
  BUY
  SELL
}
