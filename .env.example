# ──────────────────────────────────────────────
# Tibedra 환경변수 예시
# 이 파일을 복사해 .env.local 을 만들고 값을 채우세요.
# (배포 시에는 Vercel 프로젝트 환경변수에 동일하게 등록)
# ──────────────────────────────────────────────

# 사이트 절대 URL (sitemap / robots / OG 에 사용)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Google AdSense 퍼블리셔 ID  (예: ca-pub-1234567890123456)
# 발급: https://www.google.com/adsense  →  사이트 승인 후 게시자 ID 복사
NEXT_PUBLIC_ADSENSE_CLIENT=

# 광고 슬롯 ID (AdSense > 광고 > 광고 단위 만들기 에서 발급되는 숫자)
# 지면별로 다른 슬롯을 쓰고 싶으면 각각 채우세요. 비워두면 광고가 렌더되지 않습니다.
NEXT_PUBLIC_ADSENSE_SLOT_INLINE=
NEXT_PUBLIC_ADSENSE_SLOT_FEED=
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=

# Cron 보안 토큰 — /api/revalidate 무단 호출 방지용 (아무 랜덤 문자열)
REVALIDATE_TOKEN=change-me-to-a-random-string

# ── Google Gemini (번역·해설·브리핑·블로그 자동 초안) ──
# 발급: https://aistudio.google.com/apikey  (무료 등급 제공)
# 비워두면 관련 기능이 모두 비활성화됩니다(번역 없이 원문 표시, 해설 없이 요약만 표시 등).
GEMINI_API_KEY=
# 해설(analysis)·브리핑·블로그 자동 초안에 쓰는 모델 (기본: gemini-2.5-flash).
GEMINI_MODEL=gemini-2.5-flash
# 번역 전용 모델 (기본: gemini-2.5-flash-lite). 번역은 호출 빈도가 가장 높아
# GEMINI_MODEL 과 별도 모델(=별도 쿼터)을 씀으로써, 번역 트래픽이 해설/브리핑
# 쿼터를 갉아먹어 실패하는 일을 막는다(lib/gemini-throttle.ts 참고).
GEMINI_TRANSLATE_MODEL=gemini-2.5-flash-lite

# ── 네이버 지역(장소) 검색 API (맛집 섹션) ──
# 발급: https://developers.naver.com → Application 등록 → 사용 API: 검색
# 비워두면 맛집 섹션이 비활성화됩니다(빈 목록으로 표시).
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── 블로그 관리자 (/admin) ──
# /admin 로그인 비밀번호. 비워두면 관리자 기능 전체가 비활성화됩니다.
ADMIN_PASSWORD=
# 관리자 발행 글·매일 자동 초안·브리핑 아카이브 저장소(private). Vercel 프로젝트에
# Blob 스토어를 연결하면 BLOB_STORE_ID 가 자동으로 채워집니다(OIDC 인증, 별도
# 토큰 불필요). 로컬에서 이 값이 없으면 해당 기능들은 조용히 비활성화됩니다.
BLOB_STORE_ID=
# 블로그 글 대표 이미지 업로드 전용 스토어(public) 의 ID. 글 데이터 스토어와
# 분리된 이유: Vercel Blob 스토어는 생성 시 public/private 중 하나로 고정되고,
# 공개 페이지에서 <img> 로 바로 보여줄 이미지는 public 이어야 하기 때문.
# `vercel blob create-store <name> --access public` 로 만든 뒤 이 값을 채우세요.
BLOG_IMAGES_STORE_ID=
